# App
NEXT_PUBLIC_APP_NAME="Roostvasum"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Localization and maps
NEXT_PUBLIC_DEFAULT_LOCALE="id"
NEXT_PUBLIC_MAP_PROVIDER="leaflet"

# Supabase public client settings
NEXT_PUBLIC_SUPABASE_URL="http://your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-project-api-key"
# Use this only if the app is configured to read the legacy anon key name.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-project-anon-key"

# Supabase server-only settings
# Never expose this value in client-side code.
SUPABASE_SERVICE_ROLE_KEY=""

# Prisma / PostgreSQL
# Runtime connection string, commonly transaction-pooler compatible.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
# Direct or session-pooler connection string for Prisma migrations and schema operations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Google OAuth
# Usually configured in Supabase Dashboard. Keep secrets server-only.
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Optional integrations
MAP_PROVIDER_API_KEY=""
SENTRY_DSN=""
EMAIL_PROVIDER_API_KEY=""
WHATSAPP_API_TOKEN=""
